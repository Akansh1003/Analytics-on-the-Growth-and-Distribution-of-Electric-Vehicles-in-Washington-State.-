import pandas as pd
import requests
from io import StringIO

# URL for the Washington State Electric Vehicle Population Data (CSV format)
url = "https://data.wa.gov/api/views/f6w7-q2d2/rows.csv?accessType=DOWNLOAD"

# Fetch the data again
response = requests.get(url)
data = StringIO(response.text)

# Load the data into a pandas DataFrame
df =  pd.read_csv("/content/Electric_Vehicle_Population_Data(1)(in).csv")
# Total number of EVs for percentage calculations
total_evs = len(df)
# Brand-wise popularity (group by 'Make')
brand_distribution = df.groupby('Make').size().reset_index(name='EV Count')
brand_distribution['Percentage (%)'] = (brand_distribution['EV Count'] / total_evs) * 100
brand_distribution = brand_distribution.sort_values('EV Count', ascending=False)
# Model-wise popularity (group by 'Make' and 'Model')
model_distribution = df.groupby(['Make', 'Model']).size().reset_index(name='EV Count')
model_distribution['Percentage (%)'] = (model_distribution['EV Count'] / total_evs) * 100
model_distribution = model_distribution.sort_values('EV Count', ascending=False)
# Print top 10 brands to console
print("Top 10 EV Brands by Popularity in Washington State:")
print(brand_distribution.head(10).to_string(index=False))
# Print top 10 models to console
print("\nTop 10 EV Models by Popularity in Washington State:")
print(model_distribution.head(10).to_string(index=False))
# Export full distributions to Excel
with pd.ExcelWriter('washington_ev_brand_model_popularity.xlsx') as writer:
    brand_distribution.to_excel(writer, sheet_name='Brand Popularity', index=False)
    model_distribution.to_excel(writer, sheet_name='Model Popularity', index=False)

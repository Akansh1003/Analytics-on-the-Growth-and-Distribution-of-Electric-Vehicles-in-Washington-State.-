import pandas as pd
import requests
from io import StringIO

# URL for the Washington State Electric Vehicle Population Data (CSV format)
url = "https://data.wa.gov/api/views/f6w7-q2d2/rows.csv?accessType=DOWNLOAD"

# Fetch the data
response = requests.get(url)
data = StringIO(response.text)

# Load the data into a pandas DataFrame
df = pd.read_csv(data)

# Filter out rows where Electric Range is 0 or NaN (assuming 0 means not applicable, like for PHEVs)
df = df[df['Electric Range'] > 0]

# Group by 'Model Year' and calculate average electric range
range_trends = df.groupby('Model Year')['Electric Range'].agg(['mean', 'median', 'min', 'max', 'count']).reset_index()
range_trends = range_trends.rename(columns={
    'mean': 'Average Range (miles)',
    'median': 'Median Range (miles)',
    'min': 'Min Range (miles)',
    'max': 'Max Range (miles)',
    'count': 'Number of EVs'
})

# Sort by Model Year
range_trends = range_trends.sort_values('Model Year')

# Calculate year-over-year change in average range
range_trends['YoY Change in Avg Range (%)'] = range_trends['Average Range (miles)'].pct_change() * 100
range_trends['YoY Change in Avg Range (%)'] = range_trends['YoY Change in Avg Range (%)'].fillna(0)

# Print the electric range trends to the console
print("Electric Range Trends by Model Year in Washington State:")
print(range_trends.to_string(index=False))

# Export to Excel for further analysis
range_trends.to_excel('washington_ev_range_trends.xlsx', index=False)

print("\nTrends exported to 'washington_ev_range_trends.xlsx'")

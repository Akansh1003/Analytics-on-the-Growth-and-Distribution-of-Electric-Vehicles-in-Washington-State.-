import pandas as pd
import requests
from io import StringIO

# URL for the Washington State Electric Vehicle Population Data (CSV format)
url = "https://data.wa.gov/api/views/f6w7-q2d2/rows.csv?accessType=DOWNLOAD"

# Fetch the data
response = requests.get(url)
data = StringIO(response.text)

# Load the data into a pandas DataFrame
df = pd.read_csv(data)

# Total EVs
total_evs = len(df)

# Year-wise growth (using Model Year as proxy)
yearly_counts = df.groupby('Model Year').size().reset_index(name='Count')
yearly_counts = yearly_counts.sort_values('Model Year')
yearly_counts['Growth Rate (%)'] = yearly_counts['Count'].pct_change() * 100
yearly_counts['Growth Rate (%)'] = yearly_counts['Growth Rate (%)'].fillna(0)
latest_growth = yearly_counts['Growth Rate (%)'].iloc[-1] if len(yearly_counts) > 1 else 0

# County-wise distribution (top 5)
county_dist = df.groupby('County').size().reset_index(name='EV Count')
county_dist['Percentage (%)'] = (county_dist['EV Count'] / total_evs) * 100
county_dist = county_dist.sort_values('EV Count', ascending=False)
top_counties = county_dist.head(5)

# Brand popularity (top 5)
brand_dist = df.groupby('Make').size().reset_index(name='EV Count')
brand_dist['Percentage (%)'] = (brand_dist['EV Count'] / total_evs) * 100
brand_dist = brand_dist.sort_values('EV Count', ascending=False)
top_brands = brand_dist.head(5)

# Electric range trends (average by Model Year, filtered for >0 range)
df_range = df[df['Electric Range'] > 0]
range_trends = df_range.groupby('Model Year')['Electric Range'].mean().reset_index(name='Avg Range (miles)')
range_trends = range_trends.sort_values('Model Year')
range_improvement = range_trends['Avg Range (miles)'].pct_change().mean() * 100 if len(range_trends) > 1 else 0

# Derive insights
insights = [
    f"Total EVs registered: {total_evs}. This indicates the current scale of EV adoption.",
    f"Latest year-over-year growth rate: {latest_growth:.2f}%. Sustained growth suggests increasing demand; plan for infrastructure expansion.",
    f"Top counties by EV count: {', '.join(top_counties['County'].tolist())}. Focus policy incentives here to address regional disparities.",
    f"Top brands: {', '.join(top_brands['Make'].tolist())}. Support popular brands with subsidies or partnerships to accelerate adoption.",
    f"Average annual improvement in electric range: {range_improvement:.2f}%. Increasing range reduces range anxiety; invest in fast-charging networks.",
    "Overall: EV adoption is growing rapidly. Policies should prioritize charging infrastructure in high-adoption areas, incentives for diverse brands, and education on range benefits."
]

# Print insights to console
print("Key Insights for EV Planning and Policy in Washington State:")
for i, insight in enumerate(insights, 1):
    print(f"{i}. {insight}")

# Create a summary DataFrame for export
summary_df = pd.DataFrame({
    'Insight Category': [
        'Total EVs',
        'Growth Rate',
        'Top Counties',
        'Top Brands',
        'Range Improvement',
        'Overall Recommendation'
    ],
    'Details': [
        f"{total_evs} registered EVs",
        f"Latest YoY: {latest_growth:.2f}%",
        f"{', '.join(top_counties['County'].tolist())} ({', '.join([f'{p:.1f}%' for p in top_counties['Percentage (%)']])})",
        f"{', '.join(top_brands['Make'].tolist())} ({', '.join([f'{p:.1f}%' for p in top_brands['Percentage (%)']])})",
        f"Avg annual: {range_improvement:.2f}%",
        "Prioritize infrastructure, incentives, and education."
    ]
})

# Export to Excel
summary_df.to_excel('washington_ev_policy_insights.xlsx', index=False)

print("\nInsights summary exported to 'washington_ev_policy_insights.xlsx'")
